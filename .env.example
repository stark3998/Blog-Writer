# ── Azure OpenAI / AI Foundry ─────────────────────────────────────
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
PROJECT_API_KEY=your-api-key-here
MODEL_DEPLOYMENT_NAME=gpt-4o
IMAGE_MODEL_DEPLOYMENT_NAME=gpt-image-1-mini  # For auto-generated hero images
API_VERSION=2024-12-01-preview

# Optional per-agent model overrides (all default to MODEL_DEPLOYMENT_NAME)
# LINKEDIN_POST_MODEL=gpt-4o
# TWITTER_POST_MODEL=gpt-4o
# HUMANIZER_MODEL=gpt-4o
# VALIDATION_MODEL=gpt-4o

# ── Azure Cosmos DB ───────────────────────────────────────────────
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key-here
COSMOS_DATABASE=blog-writer
# COSMOS_THROUGHPUT=400  # Optional: only if using provisioned throughput (not serverless)

# ── GitHub ────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=jatmadan/portfolio

# ── LinkedIn OAuth ────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/linkedin/oauth/callback
LINKEDIN_SCOPES=openid profile w_member_social
LINKEDIN_COSMOS_SESSION_CONTAINER=linkedin-sessions
LINKEDIN_COSMOS_STATE_CONTAINER=linkedin-oauth-states
LINKEDIN_OAUTH_STATE_TTL_SECONDS=900

# ── Twitter/X OAuth 2.0 ──────────────────────────────────────────
# Create an app at https://developer.twitter.com — enable OAuth 2.0 with PKCE
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_REDIRECT_URI=http://localhost:8080/api/twitter/oauth/callback
TWITTER_SCOPES=tweet.read tweet.write users.read offline.access
TWITTER_COSMOS_SESSION_CONTAINER=twitter-sessions
TWITTER_COSMOS_STATE_CONTAINER=twitter-oauth-states
TWITTER_OAUTH_STATE_TTL_SECONDS=900

# ── Medium ────────────────────────────────────────────────────────
# No app secret needed — users connect via self-issued integration tokens
# Generate at https://medium.com/me/settings/security
MEDIUM_COSMOS_SESSION_CONTAINER=medium-sessions

# ── Auto-Crawl Feed Settings ─────────────────────────────────────
# LINKEDIN_AUTO_SESSION_ID=your-linkedin-session-id  # For auto-publishing LinkedIn posts
# DEFAULT_CRAWL_INTERVAL_MINUTES=1440  # Default crawl interval for new feed sources (24 hours)

# ── Webhook Notifications ────────────────────────────────────────
# Pipeline events (crawl_completed, blog_published, linkedin_published, errors)
# Supports: Microsoft Teams (Adaptive Cards), Slack, or generic JSON POST
# WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ── Entra ID (Azure AD) ──────────────────────────────────────────
# Leave empty to disable auth (local dev without login)
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=

# ── Diagnostics ───────────────────────────────────────────────────
# Optional API key to protect the /api/diagnostics endpoints
# DIAGNOSTICS_API_KEY=your-diagnostics-key

# ── Blog ──────────────────────────────────────────────────────────
# Your published blog base URL — used in LinkedIn/Twitter posts to link to your articles
BLOG_BASE_URL=https://your-portfolio-site.com

# ── Server ────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO

# ── Notes ─────────────────────────────────────────────────────────
# API keys (PROJECT_API_KEY, COSMOS_KEY) are optional.
# If not provided, the app uses DefaultAzureCredential (run: az login)
#
# LOG_LEVEL values:
#   DEBUG   — All details (auth method, chunk data, internal operations)
#   INFO    — Normal operation (API calls, tokens used, timing)
#   WARNING — Only warnings and errors
#   ERROR   — Only errors
