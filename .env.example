# Azure OpenAI / AI Foundry
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
PROJECT_API_KEY=your-api-key-here
MODEL_DEPLOYMENT_NAME=gpt-4o
IMAGE_MODEL_DEPLOYMENT_NAME=gpt-image-1-mini  # For auto-generated hero images
API_VERSION=2024-12-01-preview

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key-here
COSMOS_DATABASE=blog-writer
# COSMOS_THROUGHPUT=400  # Optional: only if using provisioned throughput (not serverless)

# GitHub - Personal Access Token with repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=jatmadan/portfolio

# LinkedIn OAuth (for /api/linkedin/oauth + /api/linkedin/publish)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/linkedin/oauth/callback
LINKEDIN_SCOPES=r_liteprofile w_member_social
LINKEDIN_COSMOS_SESSION_CONTAINER=linkedin-sessions
LINKEDIN_COSMOS_STATE_CONTAINER=linkedin-oauth-states
LINKEDIN_OAUTH_STATE_TTL_SECONDS=900

# Auto-Crawl Feed Settings
# LINKEDIN_AUTO_SESSION_ID=your-linkedin-session-id  # For auto-publishing LinkedIn posts
# DEFAULT_CRAWL_INTERVAL_MINUTES=60  # Default crawl interval for new feed sources

# Entra ID (Azure AD) — leave empty to disable auth (local dev without login)
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=

# Logging (DEBUG for verbose, INFO for normal, ERROR for minimal)
LOG_LEVEL=INFO

# Blog (your published blog base URL — used in LinkedIn posts to link to your articles)
BLOG_BASE_URL=https://your-portfolio-site.com

# Server
PORT=8080

# NOTE: API keys (PROJECT_API_KEY, COSMOS_KEY) are optional
# If not provided, the app will use DefaultAzureCredential (run: az login)
# 
# LOG_LEVEL values:
# - DEBUG: All details (auth method, chunk data, internal operations)
# - INFO: Normal operation details (API calls, tokens used, timing)
# - WARNING: Only warnings and errors
# - ERROR: Only errors
